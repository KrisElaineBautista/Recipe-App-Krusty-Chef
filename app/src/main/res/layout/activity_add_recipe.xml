<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#DDB44D"
    tools:context=".AddRecipe">

    <ImageView
        android:id="@+id/backbtn"
        android:layout_width="34dp"
        android:layout_height="42dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.042"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.023"
        app:srcCompat="@drawable/leftarrow"
        tools:ignore="ContentDescription" />


    <TextView
        android:id="@+id/textView"
        android:layout_width="247dp"
        android:layout_height="40dp"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/krabby"
        android:text="@string/addrecipe_krustychef"
        android:textAlignment="center"
        android:textColor="#000000"
        android:textSize="30sp"
        app:layout_constraintBottom_toTopOf="@+id/txtview"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.428"
        tools:ignore="HardcodedText,TextSizeCheck" />


    <TextView
        android:id="@+id/txtview"
        android:layout_width="201dp"
        android:layout_height="40dp"
        android:layout_marginTop="60dp"
        android:background="@drawable/rounded_corner"
        android:backgroundTint="#B0D51414"
        android:fontFamily="sans-serif-condensed"
        android:text="@string/addrecipe_addyourrecipe"
        android:textAlignment="center"
        android:textColor="#000000"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="MissingConstraints,TextSizeCheck" />


    <Button
        android:id="@+id/btnSave"
        android:layout_width="114dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:backgroundTint="#671515"
        android:text="@string/addrecipe_save"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.686"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.976"
        tools:ignore="UnknownId" />

    <Button
        android:id="@+id/btnClear"
        android:layout_width="114dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:backgroundTint="#671515"
        android:text="@string/addrecipe_clear"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.262"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.976"
        tools:ignore="UnknownId" />

    <LinearLayout
        android:id="@+id/linearLayout3"
        android:layout_width="363dp"
        android:layout_height="206dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/rounded_corner"
        android:backgroundTint="#A85E36"
        android:gravity="center_vertical"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@+id/linearLayout2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.494"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtview">




        <RelativeLayout
            android:layout_width="304dp"
            android:layout_height="51dp"




            android:layout_marginStart="10dp"
            android:layout_marginBottom="10dp">


            <EditText
                android:id="@+id/edtRecipe"
                android:layout_width="251dp"
                android:layout_height="50dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/rounded_corner"
                android:backgroundTint="#DADADA"
                android:ems="10"
                android:hint="@string/addrecipe_recipename"
                android:inputType="text"
                android:textAlignment="center"
                android:textColorHint="#757575"
                android:textSize="20sp"
                tools:ignore="DuplicateSpeakableTextCheck"
                android:autofillHints="" />


            <ImageView
                android:id="@+id/addbtn1"
                android:layout_width="50dp"
                android:layout_height="55dp"
                android:layout_alignParentEnd="true"


                android:layout_marginStart="4dp"
                android:layout_marginEnd="-4dp"
                android:layout_toEndOf="@id/edtRecipe"
                app:srcCompat="@drawable/addbtn2"
                tools:ignore="ContentDescription,ImageContrastCheck,VisualLintBounds" />




        </RelativeLayout>




        <RelativeLayout
            android:layout_width="320dp"
            android:layout_height="50dp"
            android:layout_marginStart="15dp"
            android:layout_marginBottom="10dp">


            <EditText
                android:id="@+id/edtingredients"
                android:layout_width="249dp"
                android:layout_height="match_parent"
                android:layout_alignParentStart="true"
                android:layout_marginEnd="2dp"
                android:layout_toStartOf="@+id/addbtn3"
                android:background="@drawable/rounded_corner"
                android:backgroundTint="#DADADA"
                android:ems="10"
                android:hint="@string/addrecipe_ingredients"
                android:inputType="text"
                android:textAlignment="center"
                android:textSize="20sp"
                tools:ignore="NotSibling"
                android:autofillHints="" />


            <ImageView
                android:id="@+id/addbtn2"
                android:layout_width="50dp"
                android:layout_height="55dp"
                android:layout_alignParentEnd="true"


                android:layout_marginEnd="17dp"
                android:src="@drawable/addbtn2"
                tools:ignore="ContentDescription,ImageContrastCheck" />
        </RelativeLayout>




        <RelativeLayout
            android:layout_width="320dp"
            android:layout_height="50dp"
            android:layout_marginStart="15dp">


            <EditText
                android:id="@+id/edtprocedure"
                android:layout_width="251dp"
                android:layout_height="50dp"
                android:layout_marginStart="0dp"
                android:layout_marginEnd="2dp"
                android:background="@drawable/rounded_corner"
                android:backgroundTint="#DADADA"
                android:ems="10"
                android:hint="@string/addrecipe_procedure"
                android:inputType="text"
                android:textAlignment="center"
                android:textSize="20sp"
                android:autofillHints="" />


            <ImageView
                android:id="@+id/addbtn3"
                android:layout_width="50dp"
                android:layout_height="55dp"
                android:layout_toEndOf="@id/edtprocedure"
                app:srcCompat="@drawable/addbtn2"
                tools:ignore="ContentDescription,ImageContrastCheck" />


        </RelativeLayout>
    </LinearLayout>




    <LinearLayout
        android:id="@+id/linearLayout2"
        android:layout_width="363dp"
        android:layout_height="314dp"
        android:layout_marginBottom="88dp"
        android:background="@drawable/rounded_corner"
        android:backgroundTint="#A85E36"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">




        <RelativeLayout
            android:layout_width="387dp"
            android:layout_height="61dp"
            android:layout_marginTop="15dp"
            tools:ignore="VisualLintBounds">


            <TextView
                android:id="@+id/displayName"
                android:layout_width="213dp"
                android:layout_height="51dp"
                android:layout_marginStart="54dp"
                android:background="@drawable/rounded_corner"
                android:backgroundTint="@color/white"
                android:fontFamily="sans-serif-condensed-medium"
                android:paddingTop="10dp"
                android:text="@string/addrecipe_recipenamev2"
                android:textAlignment="center"
                android:textSize="14sp" />




            <ImageView
                android:id="@+id/displayImg"
                android:layout_width="68dp"
                android:layout_height="60dp"
                android:layout_alignTop="@id/displayName"
                android:layout_marginStart="16dp"
                android:layout_toEndOf="@id/displayName"
                android:background="@drawable/rounded_corner"
                android:backgroundTint="#FFFFFF"
                app:srcCompat="@drawable/addimage"
                tools:ignore="ContentDescription" />




        </RelativeLayout>




        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="226dp"
            android:layout_marginTop="10dp">


            <TextView
                android:id="@+id/displayIngredients"
                android:layout_width="wrap_content"
                android:layout_height="213dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/rounded_corner"
                android:backgroundTint="@color/white"
                android:ems="10"
                android:fontFamily="sans-serif-condensed-medium"
                android:inputType="text"
                android:paddingLeft="10dp"
                android:paddingBottom="6dp"
                android:text="@string/addrecipe_ingredientsv2"
                android:textSize="14sp"
                tools:ignore="RtlHardcoded,RtlSymmetry,TextViewEdits" />


            <TextView
                android:id="@+id/displayProcedure"
                android:layout_width="wrap_content"
                android:layout_height="212dp"
                android:layout_marginStart="10dp"
                android:layout_toEndOf="@id/displayIngredients"
                android:background="@drawable/rounded_corner"
                android:backgroundTint="@color/white"
                android:ems="10"
                android:fontFamily="sans-serif-condensed-medium"
                android:inputType="text"
                android:paddingStart="10dp"
                android:paddingBottom="60dp"
                android:text="@string/addrecipe_procedurev2"
                android:textSize="14sp"
                tools:ignore="RtlSymmetry,TextViewEdits" />




        </RelativeLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>















